# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- FICHIERS LOCAUX / ARCHIVES ---
_archives/
_brain/
.gemini/
__pycache__/

